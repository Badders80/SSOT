{
  "id": "tpl_syndicate_agreement",
  "name": "Syndicate Agreement",
  "category": "Legal",
  "description": "17-clause legal syndicate agreement for horse racing tokenisation. Covers object, shares, duration, revenue distribution, and winding-up provisions. Variable fields are drawn from the horse repository and HLT commercial data; all other clauses are static boilerplate.",
  "tags": ["legal", "syndicate", "agreement", "horse-racing", "tokenisation"],
  "version": "1.0",
  "source": "wizard",
  "sections": [
    {
      "id": "sec_header",
      "title": "Agreement Header",
      "fields": [
        {
          "key": "syndicateName",
          "label": "Syndicate Name",
          "type": "text",
          "classification": "DERIVED",
          "autoFillSource": "horse.name + ' Syndicate'",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "horseName",
          "label": "Horse Name",
          "type": "text",
          "classification": "REUSABLE",
          "autoFillSource": "horse.name (from horse repository)",
          "required": true,
          "reusableType": "cached"
        },
        {
          "key": "date",
          "label": "Agreement Date",
          "type": "date",
          "classification": "INPUT",
          "required": true,
          "placeholder": "DD/MM/YYYY"
        }
      ]
    },
    {
      "id": "sec_variable_clauses",
      "title": "Variable Clause Fields",
      "fields": [
        {
          "key": "horseNameClause",
          "label": "Horse Name (Clause 2 – Object)",
          "type": "text",
          "classification": "REUSABLE",
          "autoFillSource": "horse.name (from horse repository)",
          "required": true,
          "reusableType": "cached"
        },
        {
          "key": "countryCode",
          "label": "Country of Registration (Clause 2 – Object)",
          "type": "text",
          "classification": "DERIVED",
          "autoFillSource": "horse.countryCode (from horse repository / HLT data)",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "leaseDurationMonths",
          "label": "Lease Duration in Months (Clauses 2 & 5)",
          "type": "number",
          "classification": "DERIVED",
          "autoFillSource": "hlt.leaseDurationMonths (from HLT commercial data)",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "numTokens",
          "label": "Number of Tokens / Shares (Clause 4)",
          "type": "number",
          "classification": "DERIVED",
          "autoFillSource": "hlt.numTokens (from HLT commercial data)",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "percentPerToken",
          "label": "Percentage Per Token (Clause 4)",
          "type": "text",
          "classification": "DERIVED",
          "autoFillSource": "calculated as 100 / hlt.numTokens formatted as percentage string",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "leasePercent",
          "label": "Lease Percentage of Horse (Clause 4)",
          "type": "text",
          "classification": "DERIVED",
          "autoFillSource": "hlt.leasePercent (from HLT commercial data)",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "leaseStartDate",
          "label": "Lease Start Date (Clause 5)",
          "type": "date",
          "classification": "INPUT",
          "required": true,
          "placeholder": "DD/MM/YYYY"
        },
        {
          "key": "leaseEndDate",
          "label": "Lease End Date (Clause 5)",
          "type": "date",
          "classification": "DERIVED",
          "autoFillSource": "leaseStartDate + leaseDurationMonths",
          "required": true,
          "derivedMethod": "formula"
        },
        {
          "key": "investorSplit",
          "label": "Investor Revenue Split % (Clause 8)",
          "type": "text",
          "classification": "REUSABLE",
          "autoFillSource": "hlt.investorSplitPercent (from HLT commercial data)",
          "required": true,
          "reusableType": "cached",
          "llmPrompt": "Given the HLT commercial data for this offering, extract the investor revenue split percentage as defined in the revenue distribution clause.",
          "outputHint": "A percentage value, e.g. '80%'"
        },
        {
          "key": "ownerSplit",
          "label": "Owner Revenue Split % (Clause 8)",
          "type": "text",
          "classification": "DERIVED",
          "autoFillSource": "100 - hlt.investorSplitPercent formatted as percentage string",
          "required": true,
          "derivedMethod": "formula"
        }
      ]
    },
    {
      "id": "sec_static_clauses",
      "title": "Static Boilerplate Clauses",
      "fields": [
        {
          "key": "staticClauseBody",
          "label": "Static Clause Content (Clauses 1, 3, 6, 7, 9, 10, 11, 12, 13, 15, 16, 17)",
          "type": "textarea",
          "classification": "STATIC",
          "autoFillSource": "boilerplate.syndicate_agreement_static_clauses",
          "required": true
        }
      ]
    },
    {
      "id": "sec_signature",
      "title": "Signature Block",
      "fields": [
        {
          "key": "signatoryName",
          "label": "Signatory Name",
          "type": "text",
          "classification": "STATIC",
          "autoFillSource": "boilerplate.signatory_name",
          "required": true,
          "defaultValue": "Alex Baddeley"
        },
        {
          "key": "signatoryTitle",
          "label": "Signatory Title",
          "type": "text",
          "classification": "STATIC",
          "autoFillSource": "boilerplate.signatory_title",
          "required": true,
          "defaultValue": "Director, Evolution Stables Ltd"
        }
      ]
    }
  ],
  "created_at": "2026-03-15T00:00:00.000Z",
  "updated_at": "2026-03-15T00:00:00.000Z"
}
